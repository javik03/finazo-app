# Database
DATABASE_URL=postgresql://finazo:your_password@localhost:5432/finazo
POSTGRES_PASSWORD=your_secure_password_here

# Claude API (for article generation)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Webhook secret (optional, for article publish API)
ARTICLE_WEBHOOK_SECRET=your_secret_here_min_16_chars

# Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Rate limiting (Upstash Redis) — https://console.upstash.com
# Create a free Redis database, copy REST URL + token from the "REST API" tab
# If not set, rate limiting is disabled (safe for dev/staging)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Pexels API (for article featured images) — https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# IndexNow — instant URL submission to Bing, Yandex, DuckDuckGo
# Key file must be hosted at https://finazo.lat/{key}.txt
INDEXNOW_KEY=your_indexnow_key_here

# Affiliate IDs (add as you get approved)
WISE_AFFILIATE_ID=
REMITLY_AFFILIATE_ID=
